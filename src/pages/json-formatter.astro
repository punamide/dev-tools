---
import Layout from '../layouts/Layout.astro';
import JsonFormatter from '../tools/JsonFormatter';
---
<Layout
  title="JSON Formatter & Validator Online"
  description="Format, validate, and minify JSON data instantly in your browser. Free online JSON beautifier with syntax error detection. No signup required."
  keywords="json formatter, json validator, json beautifier, format json online, json minifier, pretty print json"
  faq={[
    { question: "What is JSON formatting?", answer: "JSON formatting (or beautifying) adds proper indentation and line breaks to compressed JSON data, making it human-readable. It does not change the data — only the visual presentation." },
    { question: "Is this JSON formatter free?", answer: "Yes, completely free with no limits. It runs entirely in your browser — no data is sent to any server, no signup required." },
    { question: "Does formatting change my JSON data?", answer: "No. Formatting only affects whitespace and indentation. The parsed values, keys, and structure remain identical." },
    { question: "Can this tool validate JSON?", answer: "Yes. If your JSON has syntax errors (missing commas, unquoted keys, trailing commas), the tool will detect and display the specific error message." }
  ]}
>
  <JsonFormatter client:load />
  <section class="seo-content">
    <h2>Free Online JSON Formatter</h2>
    <p>Paste your JSON data and instantly format it with proper indentation, or minify it for production use. This tool validates your JSON syntax and highlights errors in real time. Works entirely in your browser — no data is sent to any server.</p>
    <h3>Features</h3>
    <ul>
      <li>Format JSON with 2 or 4 space indentation</li>
      <li>Minify JSON for smaller file sizes</li>
      <li>Instant syntax error detection with error messages</li>
      <li>Copy formatted output with one click</li>
      <li>100% client-side — your data never leaves your browser</li>
    </ul>
  </section>
</Layout>
